ninja_required_version = 1.3
cxx = /root/miniconda3/envs/slim/bin/x86_64-conda-linux-gnu-g++
nvcc = /root/miniconda3/envs/slim/bin/nvcc

cflags = -Wno-unused-result -Wsign-compare -DNDEBUG -fwrapv -O2 -Wall -fPIC -O2 -isystem /root/miniconda3/envs/slim/include -fPIC -O2 -isystem /root/miniconda3/envs/slim/include -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -ffunction-sections -pipe -isystem /root/miniconda3/envs/slim/include -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /root/miniconda3/envs/slim/include -fPIC -I/home/disk1/SLiM/src/backbone/vssm/kernels/selective_scan/csrc/selective_scan -I/root/miniconda3/envs/slim/lib/python3.10/site-packages/torch/include -I/root/miniconda3/envs/slim/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/root/miniconda3/envs/slim/lib/python3.10/site-packages/torch/include/TH -I/root/miniconda3/envs/slim/lib/python3.10/site-packages/torch/include/THC -I/root/miniconda3/envs/slim/include -I/root/miniconda3/envs/slim/include/python3.10 -c
post_cflags = -O3 -std=c++17 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=selective_scan_cuda_oflex -D_GLIBCXX_USE_CXX11_ABI=0
cuda_cflags = -I/home/disk1/SLiM/src/backbone/vssm/kernels/selective_scan/csrc/selective_scan -I/root/miniconda3/envs/slim/lib/python3.10/site-packages/torch/include -I/root/miniconda3/envs/slim/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/root/miniconda3/envs/slim/lib/python3.10/site-packages/torch/include/TH -I/root/miniconda3/envs/slim/lib/python3.10/site-packages/torch/include/THC -I/root/miniconda3/envs/slim/include -I/root/miniconda3/envs/slim/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -O3 -std=c++17 -U__CUDA_NO_HALF_OPERATORS__ -U__CUDA_NO_HALF_CONVERSIONS__ -U__CUDA_NO_BFLOAT16_OPERATORS__ -U__CUDA_NO_BFLOAT16_CONVERSIONS__ -U__CUDA_NO_BFLOAT162_OPERATORS__ -U__CUDA_NO_BFLOAT162_CONVERSIONS__ --expt-relaxed-constexpr --expt-extended-lambda --use_fast_math --ptxas-options=-v -lineinfo -gencode arch=compute_70,code=sm_70 -gencode arch=compute_80,code=sm_80 -gencode arch=compute_90,code=sm_90 --threads 4 -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=selective_scan_cuda_oflex -D_GLIBCXX_USE_CXX11_ABI=0 -ccbin /root/miniconda3/envs/slim/bin/x86_64-conda-linux-gnu-gcc
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc  $cuda_cflags -c $in -o $out $cuda_post_cflags





